<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.app.Controller">
    <top>
        <HBox spacing="10" padding="10">
            <Button text="Open" onAction="#handleOpen"/>
            <Button text="Add" onAction="#handleAdd"/>
            <Button text="Play" onAction="#handlePlay"/>
            <Button text="Pause" onAction="#handlePause"/>
            <Button text="Stop" onAction="#handleStop"/>
            <Button text="Next" onAction="#handleNext"/>
            <Button text="Previous" onAction="#handlePrevious"/>
        </HBox>
    </top>
    <center>
        <ListView fx:id="trackListView"/>
    </center>
    <bottom>
        <VBox spacing="10" padding="10">
            <Label fx:id="currentTrackLabel" text="Current Track: "/>
            <Slider fx:id="volumeSlider" min="0" max="100" value="50" onMouseReleased="#handleVolumeChange"/>
            <Label fx:id="progressLabel" text="00:00 / 00:00"/>
            <Slider fx:id="progressSlider" onMouseReleased="#handleSeek"/>
        </VBox>
    </bottom>
</BorderPane>